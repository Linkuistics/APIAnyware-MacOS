    {
      "stereotype": "paired_state",
      "name": "NSLock critical section",
      "participants": {
        "enable": {"class": "NSLock", "selector": "lock"},
        "disable": {"class": "NSLock", "selector": "unlock"}
      },
      "constraints": {
        "ordering": "every lock must have matching unlock",
        "nesting": "NSLock does NOT support nesting; use NSRecursiveLock for nested locking",
        "thread_safety": "lock and unlock must be called from the same thread",
        "error_handling": "unlock must be called even on error (bracket semantics)"
      },
      "source": "llm",
      "doc_ref": "Threading Programming Guide > Using Locks"
    },
