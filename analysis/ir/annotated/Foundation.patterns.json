{
  "framework": "Foundation",
  "api_patterns": [
    {
      "stereotype": "observer_pair",
      "name": "NSNotificationCenter observer registration",
      "participants": {
        "register": [
          {"class": "NSNotificationCenter", "selector": "addObserver:selector:name:object:"},
          {"class": "NSNotificationCenter", "selector": "addObserverForName:object:queue:usingBlock:"}
        ],
        "callback": [
          {"description": "The selector specified in addObserver:selector:name:object:"},
          {"description": "The block passed to addObserverForName:object:queue:usingBlock:"}
        ],
        "unregister": [
          {"class": "NSNotificationCenter", "selector": "removeObserver:"},
          {"class": "NSNotificationCenter", "selector": "removeObserver:name:object:"}
        ]
      },
      "constraints": {
        "ordering": "register before unregister; unregister before observer deallocation",
        "thread_safety": "addObserver/removeObserver are thread-safe; callbacks delivered on posting thread or specified queue",
        "ownership": "block-based observer returns token that must be removed; selector-based observer uses weak reference to observer object"
      },
      "source": "llm",
      "doc_ref": "Notification Programming Topics > Registering for a Notification"
    },
    {
      "stereotype": "observer_pair",
      "name": "Key-Value Observing (KVO)",
      "participants": {
        "register": [
          {"class": "NSObject", "selector": "addObserver:forKeyPath:options:context:"}
        ],
        "callback": [
          {"class": "NSObject", "selector": "observeValueForKeyPath:ofObject:change:context:"}
        ],
        "unregister": [
          {"class": "NSObject", "selector": "removeObserver:forKeyPath:"},
          {"class": "NSObject", "selector": "removeObserver:forKeyPath:context:"}
        ]
      },
      "constraints": {
        "ordering": "register before unregister; must unregister before either object deallocates",
        "thread_safety": "KVO notifications delivered on the thread that made the change",
        "ownership": "observer is not retained; crashes if observer deallocates while registered"
      },
      "source": "llm",
      "doc_ref": "Key-Value Observing Programming Guide > Registering for Key-Value Observing"
    },
    {
      "stereotype": "observer_pair",
      "name": "NSDistributedNotificationCenter observer",
      "participants": {
        "register": [
          {"class": "NSDistributedNotificationCenter", "selector": "addObserver:selector:name:object:"},
          {"class": "NSDistributedNotificationCenter", "selector": "addObserver:selector:name:object:suspensionBehavior:"}
        ],
        "callback": [
          {"description": "The selector specified during registration"}
        ],
        "unregister": [
          {"class": "NSDistributedNotificationCenter", "selector": "removeObserver:name:object:"}
        ]
      },
      "constraints": {
        "ordering": "register before unregister",
        "thread_safety": "notifications delivered on main thread",
        "ownership": "observer is not retained"
      },
      "source": "llm",
      "doc_ref": "Notification Programming Topics > Distributed Notifications"
    },
    {
      "stereotype": "resource_lifecycle",
      "name": "NSMutableAttributedString editing session",
      "participants": {
        "open": {"class": "NSMutableAttributedString", "selector": "beginEditing"},
        "operations": [
          {"class": "NSMutableAttributedString", "selector": "addAttribute:value:range:"},
          {"class": "NSMutableAttributedString", "selector": "addAttributes:range:"},
          {"class": "NSMutableAttributedString", "selector": "removeAttribute:range:"},
          {"class": "NSMutableAttributedString", "selector": "replaceCharactersInRange:withString:"},
          {"class": "NSMutableAttributedString", "selector": "setAttributes:range:"}
        ],
        "close": {"class": "NSMutableAttributedString", "selector": "endEditing"}
      },
      "constraints": {
        "ordering": "beginEditing must precede mutations; endEditing must follow all mutations",
        "thread_safety": "not thread-safe; all calls must be on same thread",
        "ownership": "no ownership transfer; editing session is a state bracket"
      },
      "source": "llm",
      "doc_ref": "Attributed String Programming Guide > Changing an Attributed String"
    },
    {
      "stereotype": "resource_lifecycle",
      "name": "NSBundleResourceRequest on-demand resource access",
      "participants": {
        "open": {"class": "NSBundleResourceRequest", "selector": "beginAccessingResourcesWithCompletionHandler:"},
        "operations": [
          {"description": "Access the bundle resources via NSBundle APIs"}
        ],
        "close": {"class": "NSBundleResourceRequest", "selector": "endAccessingResources"}
      },
      "constraints": {
        "ordering": "beginAccessing (async) must complete before using resources; endAccessing when done",
        "thread_safety": "completion handler called on arbitrary queue",
        "ownership": "system may purge resources after endAccessing"
      },
      "source": "llm",
      "doc_ref": "On-Demand Resources Guide"
    },
    {
      "stereotype": "resource_lifecycle",
      "name": "NSProcessInfo activity assertion",
      "participants": {
        "open": {"class": "NSProcessInfo", "selector": "beginActivityWithOptions:reason:"},
        "operations": [
          {"description": "Perform the activity that requires the assertion"}
        ],
        "close": {"class": "NSProcessInfo", "selector": "endActivity:"}
      },
      "constraints": {
        "ordering": "beginActivity returns token; pass token to endActivity when done",
        "thread_safety": "thread-safe",
        "ownership": "token must be retained until endActivity is called"
      },
      "source": "llm",
      "doc_ref": "Energy Efficiency Guide for Mac Apps > Prioritize Work at the App Level"
    },
    {
      "stereotype": "transaction_bracket",
      "name": "NSUndoManager undo grouping",
      "participants": {
        "begin": {"class": "NSUndoManager", "selector": "beginUndoGrouping"},
        "mutations": [
          {"class": "NSUndoManager", "selector": "registerUndoWithTarget:selector:object:"},
          {"class": "NSUndoManager", "selector": "prepareWithInvocationTarget:"}
        ],
        "commit": {"class": "NSUndoManager", "selector": "endUndoGrouping"}
      },
      "constraints": {
        "ordering": "beginUndoGrouping before mutations; endUndoGrouping after all mutations",
        "nesting": "undo groupings can nest; each begin must have matching end",
        "thread_safety": "not thread-safe"
      },
      "source": "llm",
      "doc_ref": "Undo Architecture > Grouping Undo Operations"
    },
